{
  "name": "fluid-tools",
  "version": "1.0.0",
  "description": "AI-powered API tool execution engine with LangGraph, RAG, and multi-provider LLM support",
  "main": "./dist/cjs/index.js",
  "module": "./dist/esm/index.js",
  "types": "./dist/types/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/esm/index.js",
      "require": "./dist/cjs/index.js",
      "types": "./dist/types/index.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=18.0.0"
  },
  "sideEffects": false,
  "scripts": {
    "build": "npm run build:cjs && npm run build:esm && npm run build:types",
    "build:cjs": "tsc -p tsconfig.cjs.json",
    "build:esm": "tsc -p tsconfig.esm.json",
    "build:types": "tsc -p tsconfig.types.json",
    "clean": "rimraf dist",
    "prepublishOnly": "npm run clean && npm run build",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "uuid": "^9.0.1"
  },
  "peerDependencies": {
    "@langchain/anthropic": "^1.3.22",
    "@langchain/core": "^1.1.31",
    "@langchain/google-genai": "^2.1.24",
    "@langchain/langgraph": "^1.2.1",
    "@langchain/ollama": "^1.2.6",
    "@langchain/openai": "^1.2.12",
    "axios": "^1.13.6",
    "langchain": "^1.2.30",
    "zod": "^4.3.6"
  },
  "peerDependenciesMeta": {
    "@langchain/anthropic": {
      "optional": true
    },
    "@langchain/google-genai": {
      "optional": true
    },
    "@langchain/ollama": {
      "optional": true
    },
    "@langchain/openai": {
      "optional": true
    }
  },
  "keywords": [
    "langchain",
    "langgraph",
    "rag",
    "ai",
    "tools",
    "postman",
    "llm",
    "openai",
    "anthropic",
    "gemini"
  ],
  "license": "MIT",
  "devDependencies": {
    "@langchain/anthropic": "^1.3.22",
    "@langchain/core": "^1.1.31",
    "@langchain/google-genai": "^2.1.24",
    "@langchain/langgraph": "^1.2.1",
    "@langchain/ollama": "^1.2.6",
    "@langchain/openai": "^1.2.12",
    "@types/node": "^25.3.5",
    "@types/uuid": "^10.0.0",
    "@vitest/coverage-v8": "^3.2.4",
    "axios": "^1.13.6",
    "langchain": "^1.2.30",
    "rimraf": "^6.1.3",
    "typescript": "^5.9.3",
    "vitest": "^3.2.4",
    "zod": "^4.3.6"
  }
}
